<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Xradiator.Views.MessageWindow"
        SystemDecorations="None"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        ShowInTaskbar="False"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        Topmost="True">

    <Border x:Name="Container" CornerRadius="8" Background="Black" Padding="10">
        <TextBlock x:Name="Message" Foreground="White" TextAlignment="Center" FontSize="48" />
    </Border>

</Window>
